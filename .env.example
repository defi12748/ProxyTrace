# Neon pooled PostgreSQL connection string, including sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/proxytrace?sslmode=require

# Production/deployed backend base URL, used by demo clients and Forge Remote.
PROXYTRACE_API_URL=http://localhost:8000

# Optional upstream tool service. If unset, ProxyTrace uses built-in demo Jira
# triage tools so Phase 1 can run without Atlassian credentials.
TOOL_UPSTREAM_BASE_URL=
DEMO_TOOL_MODE=true

# Phase 2+ scorer config.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Atlassian/Future Forge wiring. Phase 1 does not require these.
ATLASSIAN_SITE_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
FORGE_REMOTE_BASE_URL=
