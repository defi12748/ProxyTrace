# Neon pooled PostgreSQL connection string, including sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/proxytrace?sslmode=require

# Production/deployed backend base URL, used by demo clients and Forge Remote.
PROXYTRACE_API_URL=http://127.0.0.1:8000

# Optional upstream tool service. Leave blank when using the built-in Jira Cloud
# integration below.
TOOL_UPSTREAM_BASE_URL=

# Use false for real Jira Cloud calls. Set true only for offline sample traces.
DEMO_TOOL_MODE=false

# Phase 2+ scorer config.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Redacts emails, bearer/API-token-like values, and secret-looking fields before
# prompts/tool payloads are persisted to Neon.
REDACTION_ENABLED=true

# Atlassian Cloud wiring for real issue trace triggers and Jira comments.
ATLASSIAN_SITE_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_PROJECT_KEY=

# Forge issue-panel embedding. Only needed after the backend is deployed.
FORGE_REMOTE_BASE_URL=
